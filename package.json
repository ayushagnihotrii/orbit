{
  "name": "safespace",
  "private": true,
  "version": "0.1.0",
  "description": "SafeSpace — a safety-first social platform prototype for students 13+",
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend start:dev",
    "dev:ai": "cd ai-service && uvicorn app.main:app --reload --port 8001",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "packageManager": "pnpm@11.8.0"
}
