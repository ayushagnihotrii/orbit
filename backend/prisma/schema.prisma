// Prisma schema for SafeSpace.
// Data models are intentionally minimal — see CORE PRINCIPLE: DATA MINIMIZATION in the root README.
// User and domain models are added in Phase 2+.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  MODERATOR
  ADMIN
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// Auto-moderation state for a single piece of content (post / chat message / DM).
enum ModerationStatus {
  APPROVED
  PENDING
  REMOVED
}

enum ContentType {
  POST
  CHAT_MESSAGE
  DIRECT_MESSAGE
}

enum ReportStatus {
  PENDING
  REVIEWED
}

enum ModerationActionType {
  APPROVE
  REMOVE
  WARN
  SUSPEND
  UNSUSPEND
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  age          Int
  role         Role     @default(STUDENT)
  isPrivate    Boolean  @default(true)
  isSuspended  Boolean  @default(false)
  createdAt    DateTime @default(now())

  createdCommunities  Community[]
  communityMembership CommunityMembership[]
  posts               Post[]
  postVotes           PostVote[]
  chatMessages        ChatMessage[]

  sentConnectionRequests     ConnectionRequest[] @relation("RequestedConnections")
  receivedConnectionRequests ConnectionRequest[] @relation("ReceivedConnections")
  directMessages             DirectMessage[]

  reports                Report[]           @relation("ReportsFiled")
  moderationActionsTaken ModerationAction[] @relation("ModeratorActions")
  moderationActionsAgainst ModerationAction[] @relation("TargetUserActions")
}

// Reddit-style interest groups / school clubs — visible, joinable group spaces.
// Not a stranger-DM surface: posts and chat inside are only visible to members.
model Community {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  memberships CommunityMembership[]
  posts       Post[]
  chatRooms   ChatRoom[]
}

model CommunityMembership {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  joinedAt    DateTime @default(now())

  @@unique([userId, communityId])
}

model Post {
  id               String           @id @default(uuid())
  communityId      String
  community        Community        @relation(fields: [communityId], references: [id])
  authorId         String
  author           User             @relation(fields: [authorId], references: [id])
  body             String
  imageUrl         String?
  createdAt        DateTime         @default(now())
  moderationStatus ModerationStatus @default(APPROVED)
  toxicityScore    Float            @default(0)

  votes PostVote[]
}

// A single up/down vote covers both "likes" and downvotes without a redundant reactions table.
model PostVote {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  value     Int
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

// Visible group chat rooms scoped to a community — never a private 1-on-1 channel.
model ChatRoom {
  id          String   @id @default(uuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  name        String
  createdAt   DateTime @default(now())

  messages ChatMessage[]

  @@unique([communityId, name])
}

model ChatMessage {
  id               String           @id @default(uuid())
  chatRoomId       String
  chatRoom         ChatRoom         @relation(fields: [chatRoomId], references: [id])
  authorId         String
  author           User             @relation(fields: [authorId], references: [id])
  body             String
  createdAt        DateTime         @default(now())
  moderationStatus ModerationStatus @default(APPROVED)
  toxicityScore    Float            @default(0)
}

// A connection request doubles as the connection itself once ACCEPTED — that
// acceptance is the only thing that ever unlocks direct messaging between two users.
model ConnectionRequest {
  id          String           @id @default(uuid())
  requesterId String
  requester   User             @relation("RequestedConnections", fields: [requesterId], references: [id])
  recipientId String
  recipient   User             @relation("ReceivedConnections", fields: [recipientId], references: [id])
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  respondedAt DateTime?

  messages DirectMessage[]

  @@unique([requesterId, recipientId])
}

model DirectMessage {
  id               String            @id @default(uuid())
  connectionId     String
  connection       ConnectionRequest @relation(fields: [connectionId], references: [id])
  senderId         String
  sender           User              @relation(fields: [senderId], references: [id])
  body             String
  createdAt        DateTime          @default(now())
  moderationStatus ModerationStatus  @default(APPROVED)
  toxicityScore    Float             @default(0)
}

// Polymorphic by convention (contentType + contentId), not a DB-level FK —
// Prisma has no native cross-table relation for "one of several content tables".
model Report {
  id          String       @id @default(uuid())
  reporterId  String
  reporter    User         @relation("ReportsFiled", fields: [reporterId], references: [id])
  contentType ContentType
  contentId   String
  reason      String
  status      ReportStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  @@unique([reporterId, contentType, contentId])
}

// Append-only audit trail for every moderator action.
model ModerationAction {
  id           String               @id @default(uuid())
  moderatorId  String
  moderator    User                 @relation("ModeratorActions", fields: [moderatorId], references: [id])
  action       ModerationActionType
  contentType  ContentType?
  contentId    String?
  targetUserId String?
  targetUser   User?                @relation("TargetUserActions", fields: [targetUserId], references: [id])
  reason       String?
  createdAt    DateTime             @default(now())
}
