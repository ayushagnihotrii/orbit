// Prisma schema for SafeSpace.
// Data models are intentionally minimal — see CORE PRINCIPLE: DATA MINIMIZATION in the root README.
// User and domain models are added in Phase 2+.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  MODERATOR
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  age          Int
  role         Role     @default(STUDENT)
  isPrivate    Boolean  @default(true)
  createdAt    DateTime @default(now())
}
