# Postgres connection (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://safespace:safespace_dev_only@localhost:5432/safespace?schema=public"

# Redis (optional in v1)
REDIS_URL="redis://localhost:6379"

# JWT secrets — generate real random values for any non-local environment, never commit real secrets
JWT_ACCESS_SECRET="change-me-dev-only"
JWT_REFRESH_SECRET="change-me-dev-only"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# AI moderation microservice
AI_SERVICE_URL="http://localhost:8001"

PORT=3001
FRONTEND_URL="http://localhost:3000"
